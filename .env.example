# Firebase Configuration
# Get these from Firebase Console > Project Settings > General > Your Apps
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# Multi-tenant: Allowed Google Workspace domain
# Change this to your company's domain
VITE_ALLOWED_DOMAIN=hyose.co.jp

# Anthropic API Key (for PDF parsing via Claude)
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxx
